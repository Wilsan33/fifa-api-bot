    <style id="wpgentranslate-inline-style">
        .lang-selector {
            position: relative;
            display: inline-block;
            font-family: inherit;
            font-size: 14px;
            z-index: 50;
            height: 36px;
        }

        .lang-selector .js-lang-toggle {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-width: 84px;
            padding: 8px 10px;
            color: #f2f2f2;
            background: rgba(110, 110, 110, 0.25);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 10px;
            cursor: pointer;
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            transition: background-color .2s ease, border-color .2s ease;
        }

        .lang-selector .js-lang-toggle:hover {
            background: rgba(130, 130, 130, 0.35);
            border-color: rgba(255, 255, 255, 0.25);
        }

        .lang-selector img {
            width: 18px;
            height: 18px;
            object-fit: cover;
            border-radius: 5px;
        }

        .lang-selector .lang-arrow {
            margin-left: auto;
            border-left: 4px solid transparent;
            border-right: 4px solid transparent;
            border-top: 5px solid rgba(255, 255, 255, 0.9);
            transition: transform .2s ease;
        }

        .lang-selector.is-open .lang-arrow {
            transform: rotate(180deg);
        }

        .lang-selector .lang-list {
            margin: 8px 0 0;
            padding: 6px;
            list-style: none;
            position: absolute;
            top: 100%;
            right: 0;
            min-width: 160px;
            background: rgba(65, 65, 65, 0.75);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 10px;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
            display: none;
        }

        .lang-selector.is-open .lang-list {
            display: block;
        }

        .lang-selector .lang-list li a {
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            color: #f4f4f4;
            padding: 8px 10px;
            border-radius: 8px;
        }

        .lang-selector .lang-list li a:hover {
            background: rgba(255, 255, 255, 0.14);
        }

        .lang-selector .lang-list li.active a {
            background: rgba(255, 255, 255, 0.18);
        }
    </style>
