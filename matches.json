        <script id="wpgentranslate-inline-script">
        (function() {
            function closeAll(except) {
                var selectors = document.querySelectorAll('[data-js-lang-selector="1"]');
                selectors.forEach(function(selector) {
                    if (except && selector === except) {
                        return;
                    }
                    selector.classList.remove('is-open');
                    var btn = selector.querySelector('.js-lang-toggle');
                    if (btn) {
                        btn.setAttribute('aria-expanded', 'false');
                    }
                });
            }

            document.addEventListener('click', function(event) {
                var toggle = event.target.closest('.js-lang-toggle');
                if (!toggle) {
                    closeAll();
                    return;
                }

